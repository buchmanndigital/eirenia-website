# Diese Werte in Vercel → Projekt → Settings → Environment Variables (Production / Preview)
# eintragen. Die lokale Datei .env.local wird NICHT mit deployed.

SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=info@eirenia.de
SMTP_PASS=
EMAIL_FROM=Eirenia <info@eirenia.de>

# Optional: Link in Anmelde-Mails zur Programmseite
# NEXT_PUBLIC_SITE_URL=https://www.eirenia.de

# Nur bei Problemen: detaillierte SMTP-Logs in Vercel Functions
# SMTP_DEBUG=1

# Falls 465 von der Hosting-Umgebung blockiert wird (selten): Strato-Alternative testen
# SMTP_PORT=587
# SMTP_SECURE=0
